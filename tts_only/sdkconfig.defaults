# Minimal defaults for ESP-IDF v5.4 targeting ESP32-S3
CONFIG_IDF_TARGET="esp32s3"
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
# If UART console is used on your board, comment the next line
CONFIG_ESP_CONSOLE_UART_DEFAULT=n
# Increase main task stack size (default 3584) to avoid overflow during opus decode
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192